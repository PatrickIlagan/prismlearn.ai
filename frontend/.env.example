# --- Clerk (Auth) — from dashboard.clerk.com ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase (browser-safe anon key only) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx

# --- Live backend wiring ---
# Set NEXT_PUBLIC_USE_MOCKS=false to hit the real FastAPI backend instead of
# canned fixtures. NEXT_PUBLIC_API_URL must point at that backend (locally,
# http://localhost:8000; in production, your deployed backend's URL — e.g.
# https://prismlearn-backend.onrender.com).
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_API_URL=http://localhost:8000
