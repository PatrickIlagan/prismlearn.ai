# --- AI provider switch: "fireworks" (default) or "amd_cloud" (Gemma 4,
# self-hosted via vLLM on AMD Developer Cloud — see
# documentation/07_AMDGemmaDeployment.md). Leave unset/"fireworks" until
# that's actually stood up.
AI_PROVIDER=fireworks

# --- Fireworks AI (gpt-oss-120b, served on AMD Instinct GPUs) ---
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

# --- AMD Developer Cloud (Gemma 4 via self-hosted vLLM) — only read when
# AI_PROVIDER=amd_cloud. AMD_CLOUD_BASE_URL is your vLLM VM's address, e.g.
# http://<vm-ip>:8000/v1. AMD_CLOUD_API_KEY is optional (only needed if you
# launched vllm serve with --api-key).
AMD_CLOUD_BASE_URL=http://<vm-ip>:8000/v1
AMD_CLOUD_API_KEY=
AMD_CLOUD_MODEL=google/gemma-4-26B-A4B-it

# --- Gemma 4 on Fireworks (on-demand deployment) — optional slide/page image
# captioning during PPTX ingestion, see app/services/vision.py. Leave EMPTY
# by default: captioning is skipped entirely (zero cost, ingestion behaves
# exactly as if this didn't exist) unless a deployment is actually running.
# Not part of the always-on pipeline — a dedicated GPU deployment doesn't
# pencil out against a subscription at scale, so only set this while you've
# deliberately deployed Gemma (e.g. for a demo), then unset it again.
FIREWORKS_GEMMA_MODEL=

# --- Gemma 3 27B (Google DeepMind) on Fireworks — a TASK-level model tried
# FIRST for flashcard generation on every request (run_flashcard_generation in
# fireworks.py); tutoring/ingest/quiz stay on gpt-oss-120b regardless of this
# var, unlike AI_PROVIDER above which swaps everything. Defaults to a real
# Gemma 3 27B slug, not empty — if that call fails (as of this writing it
# always does; Gemma isn't served serverless on Fireworks yet, verified
# directly against the chat completions API), it automatically falls back to
# gpt-oss-120b. Set to empty to skip the Gemma attempt entirely.
GEMMA_FLASHCARDS_MODEL=accounts/fireworks/models/gemma3-27b-it

# --- YouTube transcript proxy — REQUIRED once deployed to a cloud host
# (Render, AWS, GCP, etc.). YouTube blocks transcript requests from cloud-
# provider IPs outright, so YouTube ingestion works locally but fails in
# production without one of these set. Webshare is youtube-transcript-api's
# own recommended fix (has built-in retry-on-block) — leave both empty and
# YOUTUBE_PROXY_URL unset for local dev, where direct requests work fine.
YOUTUBE_PROXY_WEBSHARE_USERNAME=
YOUTUBE_PROXY_WEBSHARE_PASSWORD=
YOUTUBE_PROXY_URL=

# --- Supabase (PostgreSQL + Storage) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# --- Clerk (JWT verification) ---
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_JWKS_URL=https://<your-clerk-frontend-api>.clerk.accounts.dev/.well-known/jwks.json

# --- App config ---
FRONTEND_ORIGIN=http://localhost:3000
MAX_DOCUMENT_PAGES=20
MAX_YOUTUBE_MINUTES=30
